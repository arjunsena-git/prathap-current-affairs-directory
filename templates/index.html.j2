<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="theme-color" content="#f4f7fb">
  <meta name="description" content="Daily current affairs directory for KAS and UPSC preparation.">
  <title>Prathap KM's Current Affairs Directory</title>
  <style>
    :root {
      color-scheme: light;
      --bg: #f4f7fb;
      --paper: #fffaf1;
      --surface: #ffffff;
      --surface-soft: #eef6ff;
      --text: #17202a;
      --muted: #5e6978;
      --line: #d8e0ea;
      --ink: #102131;
      --blue: #246bfe;
      --green: #05815f;
      --yellow: #d58b00;
      --red: #ca3f55;
      --violet: #7451d9;
      --teal: #007c89;
      --shadow: 0 16px 40px rgba(16, 33, 49, 0.12);
    }

    [data-theme="dark"] {
      color-scheme: dark;
      --bg: #10161d;
      --paper: #1c2027;
      --surface: #171f28;
      --surface-soft: #1d2a35;
      --text: #f4f7fb;
      --muted: #aeb8c5;
      --line: #2d3a46;
      --ink: #f4f7fb;
      --blue: #7aa7ff;
      --green: #65d7b3;
      --yellow: #ffc266;
      --red: #ff8c9b;
      --violet: #b4a0ff;
      --teal: #70dce7;
      --shadow: 0 16px 40px rgba(0, 0, 0, 0.34);
    }

    * {
      box-sizing: border-box;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      margin: 0;
      background:
        linear-gradient(90deg, rgba(36, 107, 254, 0.08), transparent 26%, rgba(5, 129, 95, 0.09) 62%, transparent),
        var(--bg);
      color: var(--text);
      font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      line-height: 1.55;
    }

    a {
      color: inherit;
      text-decoration: none;
    }

    a:hover {
      text-decoration: underline;
      text-decoration-thickness: 2px;
    }

    button,
    input {
      font: inherit;
    }

    .page {
      width: min(1120px, 100%);
      margin: 0 auto;
      padding: 14px 12px 44px;
    }

    .hero {
      display: grid;
      gap: 18px;
      padding: 18px;
      border: 1px solid var(--line);
      border-radius: 8px;
      background:
        linear-gradient(135deg, rgba(36, 107, 254, 0.14), rgba(255, 255, 255, 0) 42%),
        linear-gradient(315deg, rgba(213, 139, 0, 0.18), rgba(255, 255, 255, 0) 46%),
        var(--surface);
      box-shadow: var(--shadow);
    }

    .hero-main {
      display: grid;
      gap: 12px;
    }

    .eyebrow {
      display: inline-flex;
      width: fit-content;
      padding: 6px 9px;
      border-radius: 999px;
      background: var(--ink);
      color: var(--paper);
      font-size: 0.72rem;
      font-weight: 850;
      letter-spacing: 0.09em;
      text-transform: uppercase;
    }

    h1 {
      max-width: 12ch;
      margin: 0;
      color: var(--ink);
      font-size: clamp(2.1rem, 12vw, 5rem);
      line-height: 0.96;
      letter-spacing: 0;
    }

    .subhead {
      max-width: 62ch;
      margin: 0;
      color: var(--muted);
      font-size: 1.03rem;
    }

    .hero-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 9px;
    }

    .action,
    .theme-button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 44px;
      padding: 0 13px;
      border: 1px solid var(--line);
      border-radius: 8px;
      background: var(--surface);
      color: var(--text);
      font-weight: 800;
      cursor: pointer;
    }

    .action.primary {
      border-color: transparent;
      background: var(--blue);
      color: #ffffff;
    }

    .theme-button {
      min-width: 72px;
    }

    .stats {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 10px;
    }

    .stat {
      min-height: 90px;
      padding: 12px;
      border: 1px solid var(--line);
      border-radius: 8px;
      background: color-mix(in srgb, var(--surface) 84%, var(--surface-soft));
    }

    .stat strong {
      display: block;
      font-size: 1.35rem;
      line-height: 1;
    }

    .stat span {
      display: block;
      margin-top: 8px;
      color: var(--muted);
      font-size: 0.84rem;
      font-weight: 700;
    }

    .stat.blue {
      border-top: 5px solid var(--blue);
    }

    .stat.green {
      border-top: 5px solid var(--green);
    }

    .stat.yellow {
      border-top: 5px solid var(--yellow);
    }

    .stat.red {
      border-top: 5px solid var(--red);
    }

    .desk {
      display: grid;
      gap: 12px;
      margin: 16px 0;
      padding: 12px;
      border: 1px solid var(--line);
      border-radius: 8px;
      background: var(--surface);
      box-shadow: 0 10px 26px rgba(16, 33, 49, 0.08);
      position: sticky;
      top: 0;
      z-index: 10;
    }

    .search {
      width: 100%;
      min-height: 46px;
      padding: 0 13px;
      border: 1px solid var(--line);
      border-radius: 8px;
      background: var(--surface-soft);
      color: var(--text);
      outline: none;
    }

    .search:focus {
      border-color: var(--blue);
      box-shadow: 0 0 0 3px color-mix(in srgb, var(--blue) 18%, transparent);
    }

    .chips {
      display: flex;
      gap: 8px;
      overflow-x: auto;
      padding-bottom: 2px;
      scrollbar-width: thin;
    }

    .chip {
      flex: 0 0 auto;
      min-height: 38px;
      padding: 0 11px;
      border: 1px solid var(--line);
      border-radius: 999px;
      background: var(--surface);
      color: var(--muted);
      font-size: 0.86rem;
      font-weight: 850;
      cursor: pointer;
    }

    .chip.active {
      background: var(--ink);
      color: var(--paper);
      border-color: transparent;
    }

    .section {
      margin: 22px 0 34px;
    }

    .section-head {
      display: flex;
      align-items: end;
      justify-content: space-between;
      gap: 12px;
      margin-bottom: 12px;
    }

    .section h2 {
      margin: 0;
      color: var(--ink);
      font-size: 1.35rem;
      letter-spacing: 0;
    }

    .section-count {
      color: var(--muted);
      font-size: 0.9rem;
      font-weight: 800;
    }

    .cards {
      display: grid;
      gap: 12px;
    }

    .card {
      display: grid;
      gap: 10px;
      min-height: 240px;
      padding: 15px;
      border: 1px solid var(--line);
      border-radius: 8px;
      background: var(--surface);
      box-shadow: 0 10px 22px rgba(16, 33, 49, 0.08);
      border-top-width: 6px;
    }

    .card[data-category="National"] {
      border-top-color: var(--blue);
    }

    .card[data-category="Karnataka/State"] {
      border-top-color: var(--red);
    }

    .card[data-category="Economy"] {
      border-top-color: var(--green);
    }

    .card[data-category="Science & Tech"] {
      border-top-color: var(--violet);
    }

    .card[data-category="Environment"] {
      border-top-color: var(--teal);
    }

    .card[data-category="International"] {
      border-top-color: var(--yellow);
    }

    .card-top {
      display: flex;
      flex-wrap: wrap;
      gap: 7px;
      align-items: center;
    }

    .badge {
      display: inline-flex;
      align-items: center;
      width: fit-content;
      min-height: 27px;
      padding: 3px 8px;
      border: 1px solid var(--line);
      border-radius: 999px;
      background: var(--surface-soft);
      color: var(--muted);
      font-size: 0.78rem;
      font-weight: 850;
    }

    .badge.source {
      color: var(--ink);
    }

    .badge.warning {
      border-color: color-mix(in srgb, var(--red) 55%, var(--line));
      color: var(--red);
    }

    .card h3 {
      margin: 0;
      color: var(--ink);
      font-size: 1.08rem;
      line-height: 1.3;
      letter-spacing: 0;
    }

    .brief {
      margin: 0;
      color: var(--text);
      font-size: 0.98rem;
    }

    .exam-lens {
      margin: 0;
      padding: 10px 11px;
      border-left: 4px solid var(--yellow);
      border-radius: 0 8px 8px 0;
      background: color-mix(in srgb, var(--yellow) 13%, var(--surface));
      color: var(--muted);
      font-size: 0.91rem;
      font-weight: 650;
    }

    .card-actions {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
      margin-top: auto;
    }

    .read-link {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 38px;
      padding: 0 11px;
      border-radius: 8px;
      background: var(--ink);
      color: var(--paper);
      font-size: 0.86rem;
      font-weight: 850;
    }

    .read-link:hover {
      color: var(--paper);
    }

    .save-note {
      color: var(--muted);
      font-size: 0.82rem;
      font-weight: 750;
      text-align: right;
    }

    .empty {
      padding: 16px;
      border: 1px dashed var(--line);
      border-radius: 8px;
      color: var(--muted);
      background: var(--surface);
    }

    .no-results {
      display: none;
      margin: 20px 0;
      padding: 18px;
      border: 1px dashed var(--line);
      border-radius: 8px;
      background: var(--surface);
      color: var(--muted);
      font-weight: 750;
    }

    .source-box {
      margin-top: 28px;
      padding: 14px;
      border: 1px solid var(--line);
      border-radius: 8px;
      background: var(--surface);
    }

    .source-box summary {
      cursor: pointer;
      color: var(--ink);
      font-weight: 900;
    }

    .source-list {
      display: grid;
      gap: 8px;
      margin: 12px 0 0;
      padding: 0;
      list-style: none;
      color: var(--muted);
      font-size: 0.9rem;
    }

    .source-list li {
      display: flex;
      justify-content: space-between;
      gap: 10px;
      padding-bottom: 8px;
      border-bottom: 1px solid var(--line);
    }

    .source-list li:last-child {
      padding-bottom: 0;
      border-bottom: 0;
    }

    .footer {
      margin-top: 32px;
      color: var(--muted);
      font-size: 0.86rem;
      text-align: center;
    }

    @media (min-width: 720px) {
      .page {
        padding: 24px 22px 58px;
      }

      .hero {
        grid-template-columns: minmax(0, 1.3fr) minmax(260px, 0.7fr);
        align-items: stretch;
        padding: 26px;
      }

      .stats {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .desk {
        grid-template-columns: minmax(240px, 0.55fr) minmax(0, 1fr);
        align-items: center;
      }

      .cards {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    @media (min-width: 1020px) {
      .cards {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }
    }

    @media (max-width: 560px) {
      .hero-actions {
        display: grid;
        grid-template-columns: 1fr 1fr;
      }

      .action.primary {
        grid-column: 1 / -1;
      }

      h1 {
        max-width: 10ch;
      }
    }
  </style>
</head>
<body>
  <main class="page">
    <header class="hero">
      <div class="hero-main">
        <span class="eyebrow">KAS + UPSC current affairs desk</span>
        <h1>Prathap KM's Current Affairs Directory</h1>
        <p class="subhead">A colorful seven-day reading board that refreshes through the day, bringing the news into the page first with source links ready when he wants to go deeper.</p>
        <div class="hero-actions" aria-label="Page actions">
          <button class="action primary" id="refreshPage" type="button">Reload latest published</button>
          <a class="action" href="year-to-date.html">Year-to-date PDF</a>
          <button class="theme-button" id="themeToggle" type="button" aria-label="Toggle dark mode">Dark</button>
          <a class="action" href="#source-status">Sources</a>
        </div>
      </div>

      <section class="stats" aria-label="Digest status">
        <div class="stat blue">
          <strong>{{ item_count }}</strong>
          <span>fresh study cards</span>
        </div>
        <div class="stat green">
          <strong>7</strong>
          <span>days visible</span>
        </div>
        <div class="stat yellow">
          <strong>{{ ytd_count }}</strong>
          <span>year-to-date archive cards</span>
        </div>
        <div class="stat red">
          <strong>{{ last_updated_label.split(',')[0] }}</strong>
          <span>last update date</span>
        </div>
      </section>
    </header>

    <section class="desk" aria-label="Study filters">
      <input class="search" id="searchBox" type="search" placeholder="Search headlines, summaries, sources" autocomplete="off">
      <div class="chips" aria-label="Category filters">
        <button class="chip active" type="button" data-filter="All">All</button>
        {% for category in categories %}
        <button class="chip" type="button" data-filter="{{ category }}">{{ category }}</button>
        {% endfor %}
      </div>
    </section>

    <div class="no-results" id="noResults">No cards match this search yet.</div>

    {% for category in categories %}
    {% set items = grouped_items.get(category, []) %}
    <section class="section" data-section="{{ category }}" id="{{ category|lower|replace(' ', '-')|replace('&', 'and')|replace('/', '-') }}">
      <div class="section-head">
        <h2>{{ category }}</h2>
        <span class="section-count">{{ items|length }} cards</span>
      </div>
      <div class="cards">
        {% for item in items %}
        <article class="card" data-category="{{ category }}" data-search="{{ (item.title ~ ' ' ~ item.summary ~ ' ' ~ item.source ~ ' ' ~ category)|lower }}">
          <div class="card-top">
            <span class="badge source">{{ item.source }}</span>
            <time class="badge" datetime="{{ item.date }}">{{ item.date_label }}</time>
            {% if item.unavailable %}
            <span class="badge warning">source unavailable</span>
            {% endif %}
          </div>
          <h3>{{ item.title }}</h3>
          <p class="brief">{{ item.summary }}</p>
          <p class="exam-lens">Exam lens: place this under {{ category }} and connect it with polity, governance, economy, geography, science, or environment notes where relevant.</p>
          <div class="card-actions">
            <a class="read-link" href="{{ item.link }}" target="_blank" rel="noopener">Read source</a>
            <span class="save-note">Revise, then make one note</span>
          </div>
        </article>
        {% else %}
        <div class="empty">No fresh cards in this section yet.</div>
        {% endfor %}
      </div>
    </section>
    {% endfor %}

    <details class="source-box" id="source-status">
      <summary>Source status and update log</summary>
      <ul class="source-list">
        {% for name, status in source_status.items() %}
        <li>
          <span><a href="{{ status.url }}" target="_blank" rel="noopener">{{ name }}</a></span>
          <span>{% if status.ok %}OK, {{ status.count }} fetched{% else %}Unavailable, {{ status.count }} cached{% endif %}</span>
        </li>
        {% endfor %}
      </ul>
    </details>

    <p class="footer">Last updated: {{ last_updated_label }}. Auto-updates every 2 hours from 6 AM to 10 PM IST. Static GitHub Pages site, no login, no backend, no paid APIs.</p>
  </main>

  <script>
    const root = document.documentElement;
    const storedTheme = localStorage.getItem("theme");
    const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
    root.dataset.theme = storedTheme || (prefersDark ? "dark" : "light");

    const themeToggle = document.getElementById("themeToggle");
    const syncThemeLabel = () => {
      themeToggle.textContent = root.dataset.theme === "dark" ? "Light" : "Dark";
    };
    syncThemeLabel();

    themeToggle.addEventListener("click", () => {
      const next = root.dataset.theme === "dark" ? "light" : "dark";
      root.dataset.theme = next;
      localStorage.setItem("theme", next);
      syncThemeLabel();
    });

    document.getElementById("refreshPage").addEventListener("click", () => {
      window.location.reload();
    });

    const searchBox = document.getElementById("searchBox");
    const chips = Array.from(document.querySelectorAll(".chip"));
    const cards = Array.from(document.querySelectorAll(".card"));
    const sections = Array.from(document.querySelectorAll(".section"));
    const noResults = document.getElementById("noResults");
    let activeFilter = "All";

    function applyFilters() {
      const query = searchBox.value.trim().toLowerCase();
      let visibleCards = 0;

      cards.forEach((card) => {
        const matchesCategory = activeFilter === "All" || card.dataset.category === activeFilter;
        const matchesSearch = !query || card.dataset.search.includes(query);
        const visible = matchesCategory && matchesSearch;
        card.hidden = !visible;
        if (visible) {
          visibleCards += 1;
        }
      });

      sections.forEach((section) => {
        const visibleInSection = section.querySelectorAll(".card:not([hidden])").length;
        section.hidden = visibleInSection === 0 && (activeFilter !== section.dataset.section || query);
      });

      noResults.style.display = visibleCards === 0 ? "block" : "none";
    }

    chips.forEach((chip) => {
      chip.addEventListener("click", () => {
        activeFilter = chip.dataset.filter;
        chips.forEach((item) => item.classList.toggle("active", item === chip));
        applyFilters();
      });
    });

    searchBox.addEventListener("input", applyFilters);
  </script>
</body>
</html>
