<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="theme-color" content="#ffffff">
  <title>Prathap KM's Year-to-Date Current Affairs PDF</title>
  <style>
    :root {
      --text: #17202a;
      --muted: #5e6978;
      --line: #d8e0ea;
      --blue: #246bfe;
      --green: #05815f;
      --yellow: #d58b00;
      --red: #ca3f55;
      --paper: #ffffff;
      --soft: #f4f7fb;
    }

    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      background: var(--soft);
      color: var(--text);
      font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      line-height: 1.5;
    }

    a {
      color: inherit;
    }

    .page {
      width: min(980px, 100%);
      margin: 0 auto;
      padding: 20px 14px 48px;
    }

    .toolbar {
      position: sticky;
      top: 0;
      z-index: 10;
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 14px;
      padding: 12px;
      border: 1px solid var(--line);
      border-radius: 8px;
      background: var(--paper);
    }

    .toolbar-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }

    .button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 42px;
      padding: 0 12px;
      border: 1px solid var(--line);
      border-radius: 8px;
      background: var(--paper);
      color: var(--text);
      font-weight: 800;
      text-decoration: none;
      cursor: pointer;
    }

    .button.primary {
      border-color: transparent;
      background: var(--blue);
      color: #ffffff;
    }

    .cover,
    .section {
      margin-bottom: 18px;
      padding: 18px;
      border: 1px solid var(--line);
      border-radius: 8px;
      background: var(--paper);
    }

    .eyebrow {
      margin: 0 0 8px;
      color: var(--blue);
      font-size: 0.78rem;
      font-weight: 900;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    h1 {
      margin: 0;
      font-size: clamp(2rem, 9vw, 4.2rem);
      line-height: 1;
      letter-spacing: 0;
    }

    .subtitle {
      max-width: 68ch;
      margin: 12px 0 0;
      color: var(--muted);
      font-size: 1rem;
    }

    .facts {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 10px;
      margin-top: 16px;
    }

    .fact {
      min-height: 82px;
      padding: 12px;
      border: 1px solid var(--line);
      border-top: 5px solid var(--green);
      border-radius: 8px;
      background: var(--soft);
    }

    .fact strong {
      display: block;
      font-size: 1.35rem;
    }

    .fact span {
      color: var(--muted);
      font-weight: 750;
    }

    .section h2 {
      margin: 0 0 10px;
      padding-bottom: 8px;
      border-bottom: 2px solid var(--line);
      font-size: 1.4rem;
    }

    .handbook-intro {
      margin: 16px 0 0;
      padding: 14px;
      border-left: 5px solid var(--blue);
      border-radius: 0 8px 8px 0;
      background: var(--soft);
    }

    .handbook-intro h2 {
      margin: 0 0 8px;
      font-size: 1.2rem;
    }

    .handbook-intro ul {
      margin: 0;
      padding-left: 20px;
      color: var(--muted);
    }

    .item {
      padding: 12px 0;
      border-bottom: 1px solid var(--line);
      break-inside: avoid;
    }

    .item:last-child {
      border-bottom: 0;
    }

    .meta {
      display: flex;
      flex-wrap: wrap;
      gap: 7px;
      margin-bottom: 7px;
      color: var(--muted);
      font-size: 0.82rem;
      font-weight: 800;
    }

    .badge {
      padding: 3px 7px;
      border: 1px solid var(--line);
      border-radius: 999px;
      background: var(--soft);
    }

    .note-title {
      margin: 0 0 7px;
      font-size: 1.02rem;
      line-height: 1.32;
      letter-spacing: 0;
    }

    .remember {
      margin: 0 0 8px;
      color: var(--text);
      font-size: 1rem;
      font-weight: 760;
    }

    .exam-hook {
      margin: 0;
      padding: 9px 10px;
      border-radius: 8px;
      background: var(--soft);
      color: var(--muted);
      font-size: 0.9rem;
    }

    .source-link {
      display: block;
      margin-top: 6px;
      color: var(--muted);
      font-size: 0.82rem;
      word-break: break-word;
    }

    .empty {
      color: var(--muted);
      font-weight: 750;
    }

    .note {
      margin: 18px 0 0;
      color: var(--muted);
      font-size: 0.9rem;
    }

    @media (min-width: 760px) {
      .page {
        padding: 28px 22px 64px;
      }

      .facts {
        grid-template-columns: repeat(4, minmax(0, 1fr));
      }
    }

    @media print {
      body {
        background: #ffffff;
      }

      .page {
        width: 100%;
        padding: 0;
      }

      .toolbar {
        display: none;
      }

      .cover,
      .section {
        border: 0;
        border-radius: 0;
        padding: 0;
        margin-bottom: 18pt;
      }

      .cover {
        min-height: 92vh;
        display: flex;
        flex-direction: column;
        justify-content: center;
        page-break-after: always;
      }

      .section {
        page-break-before: always;
      }

      a {
        text-decoration: none;
      }
    }
  </style>
</head>
<body>
  <main class="page">
    <nav class="toolbar" aria-label="Report actions">
      <strong>Year-to-date report</strong>
      <div class="toolbar-actions">
        <button class="button primary" id="downloadPdf" type="button">Download / Save as PDF</button>
        <a class="button" href="index.html">Back to directory</a>
      </div>
    </nav>

    <section class="cover">
      <p class="eyebrow">KAS + UPSC current affairs archive</p>
      <h1>Prathap KM's {{ year }} Current Affairs Report</h1>
      <p class="subtitle">Collected from {{ ytd_start_label }} to {{ last_updated_label }}. This printable report is generated from the site's year-to-date archive and grouped by exam section.</p>
      <div class="facts">
        <div class="fact">
          <strong>{{ item_count }}</strong>
          <span>archive items</span>
        </div>
        <div class="fact">
          <strong>{{ categories|length }}</strong>
          <span>sections</span>
        </div>
        <div class="fact">
          <strong>{{ ytd_start_label }}</strong>
          <span>start date</span>
        </div>
        <div class="fact">
          <strong>{{ last_updated_label.split(',')[0] }}</strong>
          <span>generated date</span>
        </div>
      </div>
      <div class="handbook-intro">
        <h2>How to read this handbook</h2>
        <ul>
          <li>Read the bold note as the one-line current affairs takeaway.</li>
          <li>Use the exam hook to decide where it fits in KAS/UPSC notes.</li>
          <li>Source names are kept for verification; raw links are placed quietly below each note.</li>
        </ul>
      </div>
      <p class="note">Use the browser print dialog and choose "Save as PDF". This avoids paid services and keeps the site fully static.</p>
    </section>

    {% for category in categories %}
    {% set items = grouped_items.get(category, []) %}
    <section class="section">
      <h2>{{ category }} ({{ items|length }})</h2>
      {% for item in items %}
      <article class="item">
        <div class="meta">
          <span class="badge">{{ item.source }}</span>
          <time class="badge" datetime="{{ item.date }}">{{ item.date_label }}</time>
        </div>
        <p class="remember">{{ item.handbook_note }}</p>
        <p class="exam-hook">Exam hook: {{ item.exam_hook }}</p>
        <a class="source-link" href="{{ item.link }}">Reference source</a>
      </article>
      {% else %}
      <p class="empty">No archived items in this section yet.</p>
      {% endfor %}
    </section>
    {% endfor %}
  </main>

  <script>
    document.getElementById("downloadPdf").addEventListener("click", () => {
      window.print();
    });
  </script>
</body>
</html>
